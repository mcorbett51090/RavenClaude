# Markdown: skipped from prettier formatting/checks. Rewriting prose with
# proseWrap or reflowing list indentation produces a 160+ file diff that's
# pure noise and would conflict with the human voice maintained across
# agent definitions, skills, and rules. Markdown style is reviewed by humans
# per AGENTS.md "Code style" rules ("short, scannable, action-oriented"),
# not by prettier.
*.md
*.mdx

# This workflow file has a multi-line JS template literal at column 0 inside
# a YAML `script: |` block. PyYAML rejects the leading `**Trigger**` as an
# alias reference. GitHub Actions' Ruby YAML parser accepts it (the workflow
# runs in prod), but prettier and yamllint both choke. Excluding here until
# the template literal is refactored to use array .join('\n') or proper
# indentation that survives both parsers.
.github/workflows/researcher-reminder.yml

# Bundled third-party content keeps its upstream formatting.
plugins/power-platform/skills/record-screen/extension/
plugins/power-platform/skills/record-screen/scripts/
scripts/vendor/

# Generated artifact — produced by scripts/generate-repo-guide.py from the
# marketplace + plugin manifests. Re-running the generator already produces
# canonical output; formatting it again with prettier would just create
# pointless churn (and prettier's HTML printer would rewrite the inline CSS
# / JS blocks in ways that don't match the script's emit style).
repo-guide.html

# Generated artifacts — produced by scripts/generate-dashboards.py from each
# plugin's dashboard-schema.json. Same rationale as repo-guide.html above.
plugins/*/dashboard.html

# Generated artifacts — the Learn-tab concept registry (scripts/concepts.py) and
# the pre-rendered, theme-normalized concept diagrams + render manifest
# (scripts/render-concepts.py). Both emit canonical, byte-deterministic output
# guarded by their own --check freshness gates; prettier would only churn them.
plugins/*/concepts.json
plugins/*/knowledge/concepts/visuals/
