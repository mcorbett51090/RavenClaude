# RavenClaude marketplace — ignore consumer-side runtime artifacts and local config.

# Comfort-posture run artifacts (Thing audit logs, runaway counters, hook-events.jsonl, etc.)
.ravenclaude/runs/

# Posture-change audit log (per-project, append-only — P0.4 event substrate)
.ravenclaude/posture-events.jsonl

# Local/runtime config — not part of the committed marketplace (rc-deep-research
# substrate baseline arm + local self-heal setup notes). Templates live in
# plugins/ravenclaude-core/templates/; the live per-repo copies stay local.
.ravenclaude/run-config.json
.ravenclaude/self-heal-setup.md

# Local dashboard server logs
*.log

# Node modules (if any tooling is added)
node_modules/

# Editor / OS noise
.DS_Store

# Local Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/__pycache__/
.claude/.comfort-posture-applied.local.json

# Python cache
*.pyc
**/__pycache__/
.claude/settings.local.json

# Evals — consumer-run artifacts and private fixtures must never be committed
evals/results/
evals/**/*.private.*

# Bytecode for the new evals harness
evals/__pycache__/
.claude/worktrees/

# browser-verification debris (Playwright)
.playwright-mcp/
*-rendered.png

# report-regeneration test output — regenerated reports and QA artifacts written
# by the plugin's skills during a run; never source, never committed.
tests/fixtures/report-regeneration/_out/
