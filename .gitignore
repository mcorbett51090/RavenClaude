# ─── RavenClaude ───────────────────────────────────────────────────
# Agent worktrees are scratch space — never committed.
# Ignore contents but allow the directory itself (via .gitkeep) to be tracked,
# so a fresh clone has the dir ready for new-worktree.
.claude/worktrees/*

# Personal / machine-local Claude Code overrides.
.claude/settings.local.json

# Plan files generated by Claude Code's plan mode.
.claude/plans/

# Per-session memory (project-specific).
.claude/memory/

# ─── Secrets (never commit) ────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_dsa
id_ed25519
credentials*
secrets*
service-account*.json

# ─── OS / editor noise ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
!.vscode/settings.json.example
*.swp
*.swo
*~

# ─── Build artifacts (extend per stack) ────────────────────────────
node_modules/
dist/
build/
out/
.next/
.turbo/
.cache/
coverage/
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Go
vendor/
*.test
*.out

# Rust
target/

# ─── Worktrees keep file ───────────────────────────────────────────
# Preserve the .claude/worktrees/ directory in git without preserving its contents.
!.claude/worktrees/.gitkeep
