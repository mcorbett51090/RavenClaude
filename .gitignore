# RavenClaude marketplace — ignore consumer-side runtime artifacts and local config.

# Comfort-posture run artifacts (Thing audit logs, runaway counters,
# hook-events.jsonl from the event substrate, etc.)
.ravenclaude/runs/

# Posture-change event log (apply-comfort-posture.py event substrate, P0.4)
.ravenclaude/posture-events.jsonl

# Local dashboard server logs
*.log

# Node modules (if any tooling is added)
node_modules/

# Editor / OS noise
.DS_Store

# Local Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/__pycache__/

# Python cache
*.pyc
