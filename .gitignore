# RavenClaude marketplace — ignore consumer-side runtime artifacts and local config.

# Comfort-posture run artifacts (Thing audit logs, runaway counters, etc.)
.ravenclaude/runs/

# Local dashboard server logs
*.log

# Node modules (if any tooling is added)
node_modules/

# Editor / OS noise
.DS_Store

# Local Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/__pycache__/

# Python cache
*.pyc
