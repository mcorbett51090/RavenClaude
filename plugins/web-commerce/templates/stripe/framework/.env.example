# Stripe — FRAMEWORK tier environment variables (Next.js / Astro).
# Copy to `.env.local` (Next.js) or `.env` (Astro) and fill in with your OWN
# test-mode values from https://dashboard.stripe.com/test/apikeys.
# NEVER commit a real value — this file holds placeholders only.

# Secret key — server-side only (checkout.ts, webhook.ts). Starts sk_test_
# in test mode, sk_live_ in production. NEVER prefix this with NEXT_PUBLIC_ /
# PUBLIC_ — either prefix ships the value to the browser bundle.
STRIPE_SECRET_KEY=sk_test_xxx

# Publishable key — safe to expose client-side. Next.js: prefix with
# NEXT_PUBLIC_ to make it available in payment-element.tsx. Astro: prefix
# with PUBLIC_. Kept unprefixed here since checkout.ts (server-side) also
# reads it directly; expose a second, prefixed copy for the client bundle,
# e.g. NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret ("whsec_..."). From the Dashboard's webhook endpoint
# settings, or printed by `stripe listen --forward-to localhost:PORT/api/stripe/webhook`
# during local development.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- KV store for the webhook route's idempotency de-dup (pick ONE pair) ---
# Skip this pair entirely if your deployment is a long-lived Node process
# AND you've swapped kv-idempotency-store.ts for InMemoryIdempotencyStore
# (or your own DB) — see that file's header comment.

# Option A: Upstash Redis (https://upstash.com/docs/redis/features/restapi)
UPSTASH_REDIS_REST_URL=https://example-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Option B: Vercel KV (https://vercel.com/docs/storage/vercel-kv) — same
# REST wire protocol, different env var names. Set these INSTEAD of the
# Upstash pair above if you provisioned Vercel KV.
# KV_REST_API_URL=https://example-xxxx.kv.vercel-storage.com
# KV_REST_API_TOKEN=xxx
