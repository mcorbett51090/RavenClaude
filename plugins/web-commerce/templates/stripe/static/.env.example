# Stripe — STATIC tier environment variables.
# Copy to `.env` (or your platform's secret-manager UI) and fill in with your
# OWN test-mode values from https://dashboard.stripe.com/test/apikeys.
# NEVER commit a real value — this file holds placeholders only.

# Secret key — server-side / serverless-function only. Starts sk_test_ in
# test mode, sk_live_ in production. Used by checkout.ts (Payment Link
# generation) and webhook.ts (authorize/capture/refund/cancel calls).
STRIPE_SECRET_KEY=sk_test_xxx

# Publishable key — this tier has no client-side Stripe.js, so it is unused
# here. Included for parity with the framework tier / future Buy Button use.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret ("whsec_..."). From the Dashboard's webhook endpoint
# settings, or printed by `stripe listen --forward-to localhost:PORT/webhook`
# during local development.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional — where a completed hosted checkout redirects the buyer.
STRIPE_RETURN_URL=https://example.com/thank-you

# --- KV store for the webhook receiver's idempotency de-dup (pick ONE pair) ---

# Option A: Upstash Redis (https://upstash.com/docs/redis/features/restapi)
UPSTASH_REDIS_REST_URL=https://example-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Option B: Vercel KV (https://vercel.com/docs/storage/vercel-kv) — same
# REST wire protocol, different env var names. Set these INSTEAD of the
# Upstash pair above if you provisioned Vercel KV.
# KV_REST_API_URL=https://example-xxxx.kv.vercel-storage.com
# KV_REST_API_TOKEN=xxx
