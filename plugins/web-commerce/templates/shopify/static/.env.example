# Shopify — static tier. Copy to .env (or your host's secret manager) and
# fill in real values. NEVER commit the filled-in file.

# "your-store.myshopify.com" — no protocol, no trailing slash.
SHOPIFY_STORE_DOMAIN=xxx.myshopify.com

# Storefront API public access token (Shopify admin > Apps > your app >
# API credentials > Storefront API). Safe to expose client-side — it is NOT
# the Admin API token.
SHOPIFY_STOREFRONT_TOKEN=xxx

# Webhook signing secret (Shopify admin > Settings > Notifications >
# Webhooks, or `shopify app webhook`). SERVER-SIDE ONLY — used by webhook.ts
# to verify X-Shopify-Hmac-Sha256. Never send this to the browser.
SHOPIFY_WEBHOOK_SECRET=xxx
