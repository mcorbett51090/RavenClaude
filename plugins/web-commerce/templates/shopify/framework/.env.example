# Shopify — framework tier. Copy to .env.local (Next.js) / .env (Astro) and
# fill in real values. NEVER commit the filled-in file.

# "your-store.myshopify.com" — no protocol, no trailing slash.
SHOPIFY_STORE_DOMAIN=xxx.myshopify.com

# Storefront API access token (Shopify admin > Apps > your app > API
# credentials > Storefront API). Read server-side from process.env here;
# also safe to expose client-side if you call the Storefront API directly
# from a client component. NOT the Admin API token.
SHOPIFY_STOREFRONT_TOKEN=xxx

# Webhook signing secret (Shopify admin > Settings > Notifications >
# Webhooks, or `shopify app webhook`). SERVER-SIDE ONLY — verifies
# X-Shopify-Hmac-Sha256 in webhook.ts. Never send this to the browser.
SHOPIFY_WEBHOOK_SECRET=xxx
