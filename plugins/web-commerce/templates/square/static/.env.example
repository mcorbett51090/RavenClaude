# Square sandbox/production credentials -- see README.md for how to get
# these from the Square Developer Dashboard. NEVER commit real values; this
# file ships placeholders only (CLAUDE.md §2 #4).
SQUARE_ACCESS_TOKEN=xxx
SQUARE_APPLICATION_ID=xxx
SQUARE_LOCATION_ID=xxx
SQUARE_WEBHOOK_SIGNATURE_KEY=xxx
SQUARE_ENVIRONMENT=sandbox

# Must match the Webhook Subscription's "Notification URL" byte-for-byte --
# it is part of the HMAC input Square signs.
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-domain.example.com/api/webhooks/square

# External KV backing the serverless webhook function's idempotency store
# (pick one -- Upstash REST credentials shown; Cloudflare KV / Vercel KV
# bind differently, see README.md).
KV_REST_API_URL=xxx
KV_REST_API_TOKEN=xxx
