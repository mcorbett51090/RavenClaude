{
  "description": "Allow-list of file path globs for the RavenClaude marketplace. Both .github/workflows/validate-layout.yml and plugins/ravenclaude-core/hooks/enforce-layout.sh read this file. A new file whose path does not match any allowed_globs entry will be blocked by the hook (in Claude Code) and fail the CI workflow (on PRs). Add new globs here when introducing a new top-level directory or a new plugin.",
  "schema_version": 1,
  "allowed_globs": [
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "GETTING_STARTED.md",
    "STRATEGY.md",
    "evals/**",
    "schemas/**",
    "tests/fixtures/**",
    "tests/fixtures/data-viz/**",
    "index.html",
    "pitch.html",
    "pitch-data.json",
    "feedback-report.html",
    ".nojekyll",
    ".gitignore",
    ".gitattributes",
    ".prettierrc.json",
    "ruff.toml",
    ".prettierignore",
    ".repo-layout.json",
    ".ravenclaude/comfort-posture.yaml",
    ".ravenclaude/dispatch-config.json",
    ".ravenclaude/plugins/*.yaml",
    ".ravenclaude/run-config.json",
    ".ravenclaude/web-access.yaml",
    ".claude-plugin/marketplace.json",
    ".claude/settings.json",
    ".claude/worktrees/**",
    ".claude/settings.local.json",
    ".claude/workflows/**.js",
    ".claude/agent-memory/**",
    ".devcontainer/**",
    ".github/**",
    "docs/**",
    "scripts/**",
    "checklists/**",
    "examples/**",
    "plugins/*/.claude-plugin/plugin.json",
    "plugins/*/CLAUDE.md",
    "plugins/*/README.md",
    "plugins/*/CHANGELOG.md",
    "plugins/*/NOTICE.md",
    "plugins/*/portable/**",
    "plugins/*/agents/**",
    "plugins/*/copilot/**",
    "plugins/*/skills/**",
    "plugins/*/skills/*/*.py",
    "plugins/*/skills/*/*/*.py",
    "plugins/*/hooks/**",
    "plugins/*/monitors/**",
    "plugins/*/rules/**",
    "plugins/*/templates/**",
    "plugins/*/commands/**",
    "plugins/*/knowledge/**",
    "plugins/*/best-practices/**",
    "plugins/*/scenarios/**",
    "plugins/*/docs/**",
    "plugins/*/dashboard-schema.json",
    "plugins/*/dashboard.html",
    "plugins/*/report.html",
    "plugins/*/bi-report/**",
    "plugins/*/concepts.json",
    "plugins/*/pattern-explanations.json",
    "plugins/*/dashboard-assets/**",
    "plugins/*/scripts/**",
    "plugins/*/bin/**",
    "scripts/generate-dashboards.py",
    "scripts/serve-dashboards.py",
    "plugins/*/.lsp.json"
  ],
  "forbidden_globs": [],
  "suggestions": {
    "Power Platform content inside ravenclaude-core": "Move to plugins/power-platform/ — ravenclaude-core stays domain-neutral.",
    "Finance / EdTech / Salesforce content inside ravenclaude-core": "Create a new domain plugin under plugins/<domain>/ and add it to .claude-plugin/marketplace.json.",
    "New top-level directory": "Add the glob to .repo-layout.json allowed_globs first, with rationale in the PR description."
  }
}
