{
  "name": "RavenClaude",
  // Slim base (Ubuntu 24.04 Noble) instead of the ~19-20 GB `universal:2-linux`
  // kitchen-sink image. RavenClaude is markdown + shell + JSON manifests: it runs
  // ONLY python3, node/npx (prettier + mermaid-cli + claude-code), jq, git, gh,
  // bash, ruff, actionlint — none of universal's Java/Go/Ruby/PHP/.NET/Hugo stacks.
  // The needed toolchains come from the pinned features below (python + node +
  // github-cli); jq is installed in post-create.sh. Ubuntu 24.04 keeps post-create's
  // apt package names (the `*t64` Noble variants) valid.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  // postStartCommand fires on every Codespace start AND resume (postCreateCommand
  // only fires on first build). Auto-launch the marketplace's own dashboard so
  // the forwarded port is live the moment the Codespace is ready — no "how do I
  // find the dashboard?" hunt. Consumer repos use .ravenclaude/dashboard.sh; the
  // marketplace uses scripts/open-dashboard.sh.
  "postStartCommand": "test -x scripts/open-dashboard.sh && bash scripts/open-dashboard.sh >/tmp/rc-dashboard-postStart.log 2>&1 || true",
  // The slim base image ships the `vscode` user (only the universal image used
  // `codespace`). $HOME becomes /home/vscode — see the post-rebuild checklist in
  // the PR: re-check the memory dir, npm-global, and the dashboard port after the
  // first rebuild on this config.
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {}
  },
  // Pre-forward port 8000 so the Ports panel shows it from container start (a
  // discoverable label, even before the server binds). onAutoForward: openBrowser
  // then opens the URL in a real browser tab — not the VS Code Simple Browser,
  // which sandboxes the page — the moment the server actually answers.
  // serve-dashboards.py binds 0.0.0.0 in a Codespace so the forward is reachable.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "RavenClaude dashboard",
      "onAutoForward": "openBrowser"
    }
  }
}
