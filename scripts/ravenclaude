#!/usr/bin/env bash
# ravenclaude — install / update the RavenClaude plugins for GitHub Copilot CLI.
#
# The frictionless answer to "Copilot's plugin-update method is intolerable": we
# DON'T use Copilot's install-and-cache mechanism. Everything Copilot reads is a
# LIVE-from-disk surface, so an update is just `git pull` + a re-materialize:
#
#   * the plugin is loaded with `copilot --plugin-dir <marketplace>/plugins/ravenclaude-core/copilot`
#     (live from the directory — never installed/cached)
#   * skills live in <project>/.claude/skills      (Copilot reads .claude/skills live)
#   * hooks live in <project>/.github/hooks         (Copilot reads repo hooks live; also the
#                                                    #2540 workaround — plugin-level hooks don't fire)
#   * MCP servers are written to ~/.copilot/mcp-config.json
#
# Subcommands:
#   ravenclaude setup [--project DIR]     one-shot: install + seed & apply a balanced
#                                         comfort-posture + add an `rc` launch alias
#   ravenclaude install [--project DIR]   one-time wiring into a project (default: $PWD)
#   ravenclaude update                    git pull the marketplace + regenerate the Copilot package
#   ravenclaude status [--project DIR]    show what is wired
#   ravenclaude dashboard [--project DIR] [--port N]
#                                         open the comfort-posture dashboard scoped to a repo
#   ravenclaude init-codespace [--project DIR]
#                                         stamp the Codespace auto-setup .devcontainer/ into a repo
#
# Re-running any subcommand is safe (idempotent). After `update`, run `/skills reload`
# in your Copilot session (or relaunch) to pick up changes — no re-install ever.

set -euo pipefail

# The marketplace checkout = the repo this script lives in.
MARKET="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COPILOT_PKG="$MARKET/plugins/ravenclaude-core/copilot"
CORE="$MARKET/plugins/ravenclaude-core"
SKILLS_SRC="$CORE/skills"
GEN="$MARKET/scripts/generate-copilot-plugin.py"

note() { printf '  %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
warn() { printf '\033[33m!\033[0m %s\n' "$*" >&2; }

# Append the one-word `rc` launch alias (update + launch Copilot live) to ~/.bashrc.
# Idempotent: skips if a matching alias line is already present.
add_rc_alias() {
  local bashrc="$HOME/.bashrc"
  local line="alias rc='$MARKET/scripts/ravenclaude update && copilot --plugin-dir $COPILOT_PKG'"
  if [ -f "$bashrc" ] && grep -qF 'scripts/ravenclaude update && copilot --plugin-dir' "$bashrc"; then
    note "rc alias already in ~/.bashrc"
  else
    printf '\n# RavenClaude — launch Copilot with the live plugin (added by ravenclaude setup)\n%s\n' "$line" >> "$bashrc"
    ok "added 'rc' alias to ~/.bashrc (run: source ~/.bashrc, then 'rc')"
  fi
}

# Drop the repo-local dashboard launch surfaces into a consumer project: a self-resolving
# .ravenclaude/dashboard.sh, a .ravenclaude/README.md with the link, and a one-click VS Code
# task. All scoped to <project> — they never touch the marketplace.
wire_dashboard_launchers() {
  local project="$1"
  local tpl="$CORE/templates/dashboard-launcher"
  [ -d "$tpl" ] || { warn "dashboard-launcher template missing ($tpl) — skipped"; return 0; }
  mkdir -p "$project/.ravenclaude"
  cp "$tpl/dashboard.sh" "$project/.ravenclaude/dashboard.sh"
  chmod +x "$project/.ravenclaude/dashboard.sh"

  # The README is static: the launcher (dashboard.sh) computes the dashboard URL at runtime,
  # so there is no environment-specific link to bake in (nothing to go stale per Codespace
  # rebuild) — copy it straight across, same as the other launcher files.
  cp "$tpl/README.md" "$project/.ravenclaude/README.md"

  mkdir -p "$project/.vscode"
  if [ -f "$project/.vscode/tasks.json" ]; then
    note "left existing .vscode/tasks.json alone — add the RavenClaude task from $tpl/tasks.json by hand"
  else
    cp "$tpl/tasks.json" "$project/.vscode/tasks.json"
  fi
  ok "wired dashboard launchers (.ravenclaude/dashboard.sh + README.md + .vscode task)"
}

regen() {
  if [ -f "$GEN" ] && command -v python3 >/dev/null 2>&1; then
    python3 "$GEN" >/dev/null 2>&1 && ok "regenerated the Copilot package" \
      || warn "could not regenerate the Copilot package (using the committed copy)"
  fi
}

cmd_update() {
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  printf '== ravenclaude update ==\n'
  if git -C "$MARKET" rev-parse --git-dir >/dev/null 2>&1; then
    local branch; branch="$(git -C "$MARKET" symbolic-ref --short HEAD 2>/dev/null || echo HEAD)"
    if git -C "$MARKET" pull --ff-only >/dev/null 2>&1; then
      ok "pulled latest ($branch)"
    else
      warn "git pull --ff-only failed (local changes or diverged?) — skills/hooks still update from whatever is checked out"
    fi
  else
    warn "$MARKET is not a git checkout — nothing to pull"
  fi
  regen
  # Self-heal the repo-local dashboard launchers when update is run from inside a wired
  # consumer repo, so an improved launcher / README arrives on `update` (or the `rc` alias),
  # not only on `setup`. Skip when we're sitting in the marketplace clone itself — that uses
  # open-dashboard.sh, not the consumer launcher.
  project="$(cd "$project" 2>/dev/null && pwd || echo "$project")"
  case "$project" in
    "$MARKET" | "$MARKET"/*) : ;; # inside the marketplace — nothing to re-wire
    *)
      if [ -d "$project/.ravenclaude" ]; then
        wire_dashboard_launchers "$project"
      fi
      ;;
  esac
  ok "up to date. In your Copilot session run '/skills reload' (or relaunch) to apply."
}

# Symlink one plugin's skills into <project>/.claude/skills. Used by cmd_install
# for ravenclaude-core (always) and each --with-plugin entry. Live symlinks so a
# `git pull` of the marketplace updates skills with zero re-copy; falls back to a
# cp -r where symlinks aren't supported (e.g. Windows without dev mode).
#
# Echoes the count of skills wired. A missing plugin name (no skills dir) prints
# a warning and echoes 0 — never fails the install.
wire_plugin_skills() {
  local project="$1" plugin_name="$2"
  local skills_src="$MARKET/plugins/$plugin_name/skills"
  if [ ! -d "$skills_src" ]; then
    warn "plugin '$plugin_name' has no skills/ directory (looked at $skills_src) — skipped"
    echo 0; return 0
  fi
  mkdir -p "$project/.claude/skills"
  local n=0
  for d in "$skills_src"/*/; do
    [ -d "$d" ] || continue
    local name; name="$(basename "$d")"
    local dest="$project/.claude/skills/$name"
    rm -rf "$dest"
    ln -s "$d" "$dest" 2>/dev/null || cp -r "$d" "$dest"
    n=$((n + 1))
  done
  echo "$n"
}

cmd_install() {
  local project="$PWD"
  local extra_plugins=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --with-plugin) extra_plugins+=("$2"); shift 2 ;;
      *) shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude install -> %s ==\n' "$project"

  # 1. Skills — wire ravenclaude-core (the base kit) into <project>/.claude/skills,
  #    plus any extra plugins requested via --with-plugin. Skills are read live by
  #    Copilot and Claude, so the symlink is the only wiring needed.
  local n_core
  n_core="$(wire_plugin_skills "$project" "ravenclaude-core")"
  ok "wired $n_core skills from ravenclaude-core into .claude/skills"
  if [ "${#extra_plugins[@]}" -gt 0 ]; then
    local plugin
    for plugin in "${extra_plugins[@]}"; do
      [ -z "$plugin" ] && continue
      local n_extra
      n_extra="$(wire_plugin_skills "$project" "$plugin")"
      ok "wired $n_extra skills from $plugin"
    done
  fi

  # 2. Hooks: write a Copilot-schema hooks file into <project>/.github/hooks that
  #    routes each enforcement hook through the adapter (absolute paths into the
  #    marketplace checkout, so a git pull updates the behavior live).
  mkdir -p "$project/.github/hooks"
  local adapter="$CORE/hooks/copilot-hook-adapter.sh"
  python3 - "$project/.github/hooks/ravenclaude.json" "$adapter" "$CORE" <<'PY'
import json, sys
out, adapter, core = sys.argv[1], sys.argv[2], sys.argv[3]
h = core + "/hooks"
def bash(mode, script, *extra):
    return {"type": "command", "bash": f'"{adapter}" {mode} "{h}/{script}" ' + " ".join(extra),
            "timeoutSec": 90}
cfg = {
    "version": 1,
    "hooks": {
        "SessionStart": [bash("sessionstart", "capability-orientation.sh")],
        "PreToolUse": [
            bash("bash-pretool", "guard-destructive.sh"),
            bash("bash-pretool", "thing-orchestrator.sh"),
            bash("bash-pretool", "runaway-brake.sh"),
            bash("file-pretool", "enforce-layout.sh"),
        ],
        "PostToolUse": [
            bash("posttool", "format-on-write.sh"),
            bash("posttool", "claim-grounding-lint.sh"),
        ],
        "Stop": [
            bash("stop", "dod-gate.sh"),
            bash("stop", "remind-tests.sh"),
            bash("stop", "stream-session-close.sh"),
        ],
        "UserPromptSubmit": [
            bash("userpromptsubmit", "stream-prompt-attribute.sh"),
        ],
    },
}
open(out, "w").write(json.dumps(cfg, indent=2) + "\n")
PY
  ok "wired hooks into .github/hooks/ravenclaude.json (via the Copilot adapter)"

  # 3. MCP: merge the package's bundled servers into ~/.copilot/mcp-config.json.
  local mcp_src="$COPILOT_PKG/.mcp.json"
  local mcp_dest="${COPILOT_HOME:-$HOME/.copilot}/mcp-config.json"
  if [ -f "$mcp_src" ]; then
    mkdir -p "$(dirname "$mcp_dest")"
    python3 - "$mcp_src" "$mcp_dest" <<'PY'
import json, sys
src, dest = sys.argv[1], sys.argv[2]
try:
    add = json.load(open(src)).get("mcpServers", {})
except Exception:
    add = {}
try:
    cur = json.load(open(dest))
except Exception:
    cur = {}
cur.setdefault("mcpServers", {}).update(add)
open(dest, "w").write(json.dumps(cur, indent=2) + "\n")
print(f"  merged {len(add)} MCP server(s) into {dest}")
PY
    ok "merged bundled MCP servers into $mcp_dest"
  fi

  # 4. The launch alias — one command that updates then launches Copilot live.
  #    Suppressed when invoked by `setup`, which writes the alias to ~/.bashrc itself.
  if [ -z "${RC_FROM_SETUP:-}" ]; then
    printf '\nAdd this to your shell rc (~/.bashrc / ~/.zshrc) for one-command use:\n\n'
    printf "  alias rc='%s/scripts/ravenclaude update && copilot --plugin-dir %s'\n\n" "$MARKET" "$COPILOT_PKG"
    ok "install complete. Launch with:  copilot --plugin-dir $COPILOT_PKG"
    note "Updates from now on: just run 'ravenclaude update' (or 'rc'). No re-install, ever."
  fi
}

cmd_status() {
  local project="$PWD"
  local fix=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --fix) fix=1; shift ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude status -> %s ==\n' "$project"
  [ -d "$project/.claude/skills" ] && note "skills:  $(find "$project/.claude/skills" -maxdepth 1 -mindepth 1 -type l -o -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ') in .claude/skills" || note "skills:  not wired"
  [ -f "$project/.github/hooks/ravenclaude.json" ] && note "hooks:   .github/hooks/ravenclaude.json present" || note "hooks:   not wired"
  [ -f "${COPILOT_HOME:-$HOME/.copilot}/mcp-config.json" ] && note "mcp:     ~/.copilot/mcp-config.json present" || note "mcp:     not configured"
  [ -d "$COPILOT_PKG" ] && note "package: $COPILOT_PKG" || note "package: MISSING — run 'ravenclaude update' to generate it"

  # Dashboard launcher check (v0.113.2): added because pre-v0.44.0 `ravenclaude
  # setup` installs predate the launcher template and never got the per-repo
  # dashboard.sh / README.md / .vscode/tasks.json. Without these, the consumer
  # can't open the comfort-posture editor scoped to their repo — they have to
  # remember the command.
  local launcher="$project/.ravenclaude/dashboard.sh"
  local readme="$project/.ravenclaude/README.md"
  local vstask="$project/.vscode/tasks.json"
  local launcher_missing=0
  [ -f "$launcher" ] || launcher_missing=1
  [ -f "$readme" ] || launcher_missing=1
  [ -f "$vstask" ] || launcher_missing=1
  if [ "$launcher_missing" -eq 0 ]; then
    note "launcher: .ravenclaude/dashboard.sh + README.md + VS Code task present"
  else
    if [ "$fix" -eq 1 ]; then
      note "launcher: MISSING — installing now"
      wire_dashboard_launchers "$project"
    else
      note "launcher: MISSING — run 'ravenclaude status --fix --project $project' to install"
      [ ! -f "$launcher" ] && note "          ↳ .ravenclaude/dashboard.sh absent"
      [ ! -f "$readme" ]   && note "          ↳ .ravenclaude/README.md absent"
      [ ! -f "$vstask" ]   && note "          ↳ .vscode/tasks.json absent"
    fi
  fi
}

cmd_setup() {
  local project="$PWD"
  local install_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --with-plugin) install_args+=("--with-plugin" "$2"); shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude setup -> %s ==\n' "$project"

  # 1. Wire skills + hooks + MCP (RC_FROM_SETUP suppresses install's alias hint).
  #    Threads any --with-plugin entries through to cmd_install.
  export RC_FROM_SETUP=1
  cmd_install --project "$project" "${install_args[@]:-}"
  unset RC_FROM_SETUP

  # 2. Seed a balanced comfort-posture if the repo doesn't already have one.
  local posture="$project/.ravenclaude/comfort-posture.yaml"
  local seed="$CORE/templates/comfort-posture-balanced.yaml"
  if [ -f "$posture" ]; then
    note "comfort-posture.yaml already present — left as-is"
  elif [ -f "$seed" ]; then
    mkdir -p "$project/.ravenclaude"
    cp "$seed" "$posture"
    ok "seeded .ravenclaude/comfort-posture.yaml (balanced default)"
  else
    warn "balanced posture template missing ($seed) — skipped posture seed"
  fi

  # 3. Apply the posture to .claude/settings.json (best-effort).
  local apply="$CORE/scripts/apply-comfort-posture.py"
  if [ -f "$posture" ] && [ -f "$apply" ] && command -v python3 >/dev/null 2>&1; then
    python3 "$apply" --project-root "$project" >/dev/null 2>&1 \
      && ok "applied comfort-posture -> .claude/settings.json" \
      || warn "could not apply comfort-posture (open the dashboard or run /set-posture later)"
  fi

  # 4. The one-word launch alias.
  add_rc_alias

  # 5. Repo-local comfort-posture dashboard launchers (scoped to this repo).
  wire_dashboard_launchers "$project"

  ok "setup complete."
  note ""
  note "Launch Copilot (in a NEW terminal so ~/.bashrc is loaded):"
  note "    rc"
  note "  From a non-interactive shell (e.g. inside a Copilot session itself):"
  note "    bash -i -c rc"
  note "  Or skip the alias entirely:"
  note "    copilot --plugin-dir $COPILOT_PKG"
  note ""
  note "Dashboard (comfort-posture editor):"
  if [ -n "${CODESPACES:-}" ] || [ -n "${CODESPACE_NAME:-}" ]; then
    note "    auto-launches on next Codespace start at the forwarded port 8000"
    note "    (Ports panel → 'RavenClaude dashboard' → Open in Browser)"
    note "  Run it now without restarting:"
  else
    note "    auto-launches on every Codespace start at http://127.0.0.1:8000"
    note "  Or run it now:"
  fi
  note "    bash .ravenclaude/dashboard.sh"
  note "    # (or the VS Code task: 'RavenClaude: Comfort-posture dashboard')"
}

cmd_init_codespace() {
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude init-codespace -> %s ==\n' "$project"
  local tpl="$CORE/templates/codespace-copilot"
  [ -d "$tpl" ] || { warn "template missing: $tpl"; return 1; }
  mkdir -p "$project/.devcontainer"
  local existing="$project/.devcontainer/devcontainer.json"
  if [ -f "$existing" ]; then
    warn ".devcontainer/devcontainer.json exists — NOT overwritten."
    # Check which of the four merge-required keys are missing from the existing
    # file, and list ONLY those (so a partial existing devcontainer doesn't get
    # the same generic warning as a virgin one). Falls back to listing all four
    # if python3/jq are unavailable.
    local missing=()
    if command -v python3 >/dev/null 2>&1; then
      local report
      report="$(python3 - "$existing" <<'PY' 2>/dev/null || true
import json, re, sys
try:
    raw = open(sys.argv[1]).read()
    # Strip // line comments so the devcontainer JSONC parses.
    raw = re.sub(r"//[^\n]*", "", raw)
    cfg = json.loads(raw)
except Exception:
    print("ALL")
    raise SystemExit
required = ["postCreateCommand", "postStartCommand", "forwardPorts", "portsAttributes"]
missing = [k for k in required if k not in cfg]
# postCreateCommand is "present" but still needs to invoke our post-create script.
if "postCreateCommand" in cfg:
    pc = cfg["postCreateCommand"]
    if isinstance(pc, str) and "ravenclaude-post-create.sh" not in pc:
        missing.insert(0, "postCreateCommand (must invoke ravenclaude-post-create.sh)")
print("\n".join(missing) if missing else "NONE")
PY
)"
      if [ "$report" = "NONE" ]; then
        note "  all four merge keys already present — nothing to merge"
      elif [ "$report" = "ALL" ] || [ -z "$report" ]; then
        note "  merge these keys from $tpl/devcontainer.json:"
        note "    - postCreateCommand   (must invoke .devcontainer/ravenclaude-post-create.sh)"
        note "    - postStartCommand    (auto-launches the dashboard on every Codespace start/resume)"
        note "    - forwardPorts        (pre-forwards port 8000 so the Ports panel shows it)"
        note "    - portsAttributes     (labels port 8000 and opens it in the browser)"
      else
        note "  merge these missing keys from $tpl/devcontainer.json:"
        while IFS= read -r k; do
          [ -n "$k" ] && note "    - $k"
        done <<<"$report"
      fi
    else
      note "  merge these keys from $tpl/devcontainer.json:"
      note "    - postCreateCommand   (must invoke .devcontainer/ravenclaude-post-create.sh)"
      note "    - postStartCommand    (auto-launches the dashboard on every Codespace start/resume)"
      note "    - forwardPorts        (pre-forwards port 8000)"
      note "    - portsAttributes     (labels port 8000, opens in browser)"
    fi
  else
    cp "$tpl/devcontainer.json" "$existing"
    ok "wrote .devcontainer/devcontainer.json"
  fi
  cp "$tpl/ravenclaude-post-create.sh" "$project/.devcontainer/ravenclaude-post-create.sh"
  chmod +x "$project/.devcontainer/ravenclaude-post-create.sh"
  ok "wrote .devcontainer/ravenclaude-post-create.sh"
  note "Commit .devcontainer/ and (re)build the Codespace — setup then runs automatically."
}

cmd_dashboard() {
  local project="$PWD" port="8000"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  local server="$CORE/scripts/serve-dashboards.py"
  [ -f "$server" ] || { warn "dashboard server missing: $server"; return 1; }
  printf '== ravenclaude dashboard -> %s ==\n' "$project"
  note "Open the URL it prints (Codespace: Ports panel -> Open in Browser). Ctrl+C to stop."
  # --project-root pins the repo; the server hard-refuses if it ever resolves to the marketplace.
  exec python3 "$server" --project-root "$project" --port "$port"
}

cmd_doctor() {
  # ravenclaude doctor — repo health check.
  # Five checks, each prints OK / WARN / FAIL. Exits 0 if no FAIL, 1 otherwise.
  # Designed to be safe to run anywhere — never mutates state.
  local fail=0 warning=0
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude doctor -> %s ==\n' "$project"

  # 1. .repo-layout.json present + parses
  if [ -f "$project/.repo-layout.json" ]; then
    if python3 -m json.tool "$project/.repo-layout.json" >/dev/null 2>&1; then
      ok ".repo-layout.json parses"
    else
      printf '\033[31mx\033[0m .repo-layout.json present but invalid JSON\n'; fail=$((fail+1))
    fi
  else
    warn ".repo-layout.json missing (run /init-agent-ready to seed)"; warning=$((warning+1))
  fi

  # 2. .ravenclaude/comfort-posture.yaml present (informational)
  if [ -f "$project/.ravenclaude/comfort-posture.yaml" ]; then
    ok "comfort-posture.yaml present"
  else
    warn "comfort-posture.yaml missing (run /dashboard or /set-posture)"; warning=$((warning+1))
  fi

  # 3. .claude/settings.json present + parses (the applied posture)
  if [ -f "$project/.claude/settings.json" ]; then
    if python3 -m json.tool "$project/.claude/settings.json" >/dev/null 2>&1; then
      ok ".claude/settings.json parses"
    else
      printf '\033[31mx\033[0m .claude/settings.json present but invalid JSON\n'; fail=$((fail+1))
    fi
  else
    warn ".claude/settings.json missing (Claude Code will use built-in defaults)"; warning=$((warning+1))
  fi

  # 4. Knowledge-health summary (if running in the marketplace repo)
  if [ -d "$project/plugins" ] && [ -x "$project/plugins/ravenclaude-core/scripts/knowledge-health.py" ]; then
    local out stale untracked
    out="$(python3 "$project/plugins/ravenclaude-core/scripts/knowledge-health.py" --json 2>/dev/null)" || out=""
    if [ -n "$out" ]; then
      stale="$(printf '%s' "$out" | python3 -c "import json,sys; print(json.load(sys.stdin)['counts']['stale'])" 2>/dev/null)"
      untracked="$(printf '%s' "$out" | python3 -c "import json,sys; print(json.load(sys.stdin)['counts']['untracked'])" 2>/dev/null)"
      if [ "${stale:-0}" -gt 0 ]; then
        printf '\033[31mx\033[0m knowledge-health: %s stale file(s); run scripts/knowledge-health.py\n' "$stale"
        fail=$((fail+1))
      elif [ "${untracked:-0}" -gt 0 ]; then
        warn "knowledge-health: ${untracked} untracked file(s) (missing Last reviewed: date)"; warning=$((warning+1))
      else
        ok "knowledge-health: nothing stale"
      fi
    fi
  fi

  # 5. Layout-gate self-check (every committed file matches an allowed glob)
  if [ -x "$project/scripts/check-layout.py" ]; then
    if (cd "$project" && python3 scripts/check-layout.py --all >/dev/null 2>&1); then
      ok "layout-gate: every file matches an allowed_glob"
    else
      printf '\033[31mx\033[0m layout-gate: some files do NOT match .repo-layout.json - run scripts/check-layout.py\n'
      fail=$((fail+1))
    fi
  fi

  # 6. Plugin version alignment — every plugin.json version matches its
  #    marketplace.json entry. Reuses scripts/check-marketplace-claims.py as a
  #    subprocess (single source of truth for marketplace drift checks).
  if [ -x "$project/scripts/check-marketplace-claims.py" ]; then
    if (cd "$project" && python3 scripts/check-marketplace-claims.py >/dev/null 2>&1); then
      ok "plugin version alignment: all plugins match marketplace.json"
    else
      printf '\033[31mx\033[0m plugin version alignment: plugin.json/marketplace.json drift detected - run scripts/check-marketplace-claims.py\n'
      fail=$((fail+1))
    fi
  fi

  # 7. Worktree + run-artifact age — surface aging artifacts before they
  #    become confusing. Worktree >90 days → fail (likely abandoned); >30 days
  #    → warn. Run dirs >90 days → warn (archival hint, never fail — may
  #    contain partner-confidential artifacts the user should hand-archive).
  if [ -d "$project/.claude/worktrees" ]; then
    local wt_old=0 wt_warn=0
    for wt in "$project"/.claude/worktrees/*/; do
      [ -d "$wt" ] || continue
      local age_days
      # Pass path via env var so a worktree dir name with shell- or Python-
      # injectable characters can't escape into the source. The slug
      # enforced by worktree-new.sh is safe, but doctor surveys whatever
      # exists on disk, including dirs created by other means.
      age_days="$(WT="$wt" python3 -c 'import os,time; print(int((time.time()-os.path.getmtime(os.environ["WT"]))/86400))' 2>/dev/null)"
      if [ "${age_days:-0}" -gt 90 ]; then wt_old=$((wt_old+1))
      elif [ "${age_days:-0}" -gt 30 ]; then wt_warn=$((wt_warn+1))
      fi
    done
    if [ "$wt_old" -gt 0 ]; then
      printf '\033[31mx\033[0m worktree hygiene: %s worktree(s) > 90 days old; run scripts/worktree-clean.sh --status\n' "$wt_old"
      fail=$((fail+1))
    elif [ "$wt_warn" -gt 0 ]; then
      warn "worktree hygiene: ${wt_warn} worktree(s) > 30 days old"; warning=$((warning+1))
    else
      ok "worktree hygiene: no aging worktrees"
    fi
  fi
  if [ -d "$project/.ravenclaude/runs" ]; then
    local run_old=0
    for r in "$project"/.ravenclaude/runs/*/; do
      [ -d "$r" ] || continue
      local age_days
      # Same env-var pattern as the worktree loop above — run dir names
      # come from agent dispatch (.ravenclaude/runs/<slug>/) and could
      # in principle contain unexpected characters.
      age_days="$(RDIR="$r" python3 -c 'import os,time; print(int((time.time()-os.path.getmtime(os.environ["RDIR"]))/86400))' 2>/dev/null)"
      if [ "${age_days:-0}" -gt 90 ]; then run_old=$((run_old+1)); fi
    done
    if [ "$run_old" -gt 0 ]; then
      warn "run-artifact hygiene: ${run_old} run dir(s) > 90 days old (archive if no longer needed)"; warning=$((warning+1))
    else
      ok "run-artifact hygiene: no aging runs"
    fi
  fi

  printf -- '----\n'
  if [ "$fail" -eq 0 ] && [ "$warning" -eq 0 ]; then
    ok "doctor: all checks passed"
    return 0
  fi
  if [ "$fail" -eq 0 ]; then
    note "doctor: $warning warning(s); no hard failures"
    return 0
  fi
  warn "doctor: $fail failure(s), $warning warning(s)"
  return 1
}

case "${1:-}" in
  setup)          shift; cmd_setup "$@" ;;
  install)        shift; cmd_install "$@" ;;
  update)         cmd_update ;;
  status)         shift; cmd_status "$@" ;;
  dashboard)      shift; cmd_dashboard "$@" ;;
  doctor)         shift; cmd_doctor "$@" ;;
  init-codespace) shift; cmd_init_codespace "$@" ;;
  *) printf 'usage: ravenclaude {setup|install|update|status|dashboard|doctor|init-codespace} [--project DIR]\n'; exit 2 ;;
esac
