#!/usr/bin/env bash
# ravenclaude — install / update the RavenClaude plugins for GitHub Copilot CLI.
#
# The frictionless answer to "Copilot's plugin-update method is intolerable": we
# DON'T use Copilot's install-and-cache mechanism. Everything Copilot reads is a
# LIVE-from-disk surface, so an update is just `git pull` + a re-materialize:
#
#   * the plugin is loaded with `copilot --plugin-dir <marketplace>/plugins/ravenclaude-core/copilot`
#     (live from the directory — never installed/cached)
#   * skills live in <project>/.claude/skills      (Copilot reads .claude/skills live)
#   * hooks live in <project>/.github/hooks         (Copilot reads repo hooks live; also the
#                                                    #2540 workaround — plugin-level hooks don't fire)
#   * MCP servers are written to ~/.copilot/mcp-config.json
#
# Subcommands:
#   ravenclaude setup [--project DIR]     one-shot: install + seed & apply a balanced
#                                         comfort-posture + add an `rc` launch alias
#   ravenclaude install [--project DIR]   one-time wiring into a project (default: $PWD)
#   ravenclaude update                    git pull the marketplace + regenerate the Copilot package
#   ravenclaude status [--project DIR]    show what is wired
#   ravenclaude dashboard [--project DIR] [--port N]
#                                         open the comfort-posture dashboard scoped to a repo
#   ravenclaude init-codespace [--project DIR]
#                                         stamp the Codespace auto-setup .devcontainer/ into a repo
#
# Re-running any subcommand is safe (idempotent). After `update`, run `/skills reload`
# in your Copilot session (or relaunch) to pick up changes — no re-install ever.

set -euo pipefail

# The marketplace checkout = the repo this script lives in.
MARKET="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COPILOT_PKG="$MARKET/plugins/ravenclaude-core/copilot"
CORE="$MARKET/plugins/ravenclaude-core"
SKILLS_SRC="$CORE/skills"
GEN="$MARKET/scripts/generate-copilot-plugin.py"

note() { printf '  %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
warn() { printf '\033[33m!\033[0m %s\n' "$*" >&2; }

# Append the one-word `rc` launch alias (update + launch Copilot live) to ~/.bashrc.
# Idempotent: skips if a matching alias line is already present.
add_rc_alias() {
  local bashrc="$HOME/.bashrc"
  local line="alias rc='$MARKET/scripts/ravenclaude update && copilot --plugin-dir $COPILOT_PKG'"
  if [ -f "$bashrc" ] && grep -qF 'scripts/ravenclaude update && copilot --plugin-dir' "$bashrc"; then
    note "rc alias already in ~/.bashrc"
  else
    printf '\n# RavenClaude — launch Copilot with the live plugin (added by ravenclaude setup)\n%s\n' "$line" >> "$bashrc"
    ok "added 'rc' alias to ~/.bashrc (run: source ~/.bashrc, then 'rc')"
  fi
}

# Drop the repo-local dashboard launch surfaces into a consumer project: a self-resolving
# .ravenclaude/dashboard.sh, a .ravenclaude/README.md with the link, and a one-click VS Code
# task. All scoped to <project> — they never touch the marketplace.
wire_dashboard_launchers() {
  local project="$1"
  local tpl="$CORE/templates/dashboard-launcher"
  [ -d "$tpl" ] || { warn "dashboard-launcher template missing ($tpl) — skipped"; return 0; }
  mkdir -p "$project/.ravenclaude"
  cp "$tpl/dashboard.sh" "$project/.ravenclaude/dashboard.sh"
  chmod +x "$project/.ravenclaude/dashboard.sh"

  # README carries a clickable dashboard link computed for THIS environment: the live
  # Codespace-forwarded URL when in a Codespace, else localhost (port 8000 = the default).
  local dash_url
  if [ -n "${CODESPACE_NAME:-}" ]; then
    dash_url="https://${CODESPACE_NAME}-8000.${GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN:-app.github.dev}/dashboard.html"
  else
    dash_url="http://127.0.0.1:8000/dashboard.html"
  fi
  python3 - "$tpl/README.md" "$project/.ravenclaude/README.md" "$dash_url" <<'PY'
import sys
src, dest, url = sys.argv[1], sys.argv[2], sys.argv[3]
open(dest, "w", encoding="utf-8").write(
    open(src, encoding="utf-8").read().replace("__RC_DASHBOARD_URL__", url)
)
PY
  # The link is environment-specific (a Codespace name changes per rebuild), so keep the
  # generated README out of git to avoid churn — setup regenerates it fresh each time.
  local gi="$project/.gitignore"
  if ! { [ -f "$gi" ] && grep -qxF ".ravenclaude/README.md" "$gi"; }; then
    printf '%s\n' ".ravenclaude/README.md" >> "$gi"
  fi

  mkdir -p "$project/.vscode"
  if [ -f "$project/.vscode/tasks.json" ]; then
    note "left existing .vscode/tasks.json alone — add the RavenClaude task from $tpl/tasks.json by hand"
  else
    cp "$tpl/tasks.json" "$project/.vscode/tasks.json"
  fi
  ok "wired dashboard launchers (.ravenclaude/dashboard.sh + README.md + .vscode task)"
}

regen() {
  if [ -f "$GEN" ] && command -v python3 >/dev/null 2>&1; then
    python3 "$GEN" >/dev/null 2>&1 && ok "regenerated the Copilot package" \
      || warn "could not regenerate the Copilot package (using the committed copy)"
  fi
}

cmd_update() {
  printf '== ravenclaude update ==\n'
  if git -C "$MARKET" rev-parse --git-dir >/dev/null 2>&1; then
    local branch; branch="$(git -C "$MARKET" symbolic-ref --short HEAD 2>/dev/null || echo HEAD)"
    if git -C "$MARKET" pull --ff-only >/dev/null 2>&1; then
      ok "pulled latest ($branch)"
    else
      warn "git pull --ff-only failed (local changes or diverged?) — skills/hooks still update from whatever is checked out"
    fi
  else
    warn "$MARKET is not a git checkout — nothing to pull"
  fi
  regen
  ok "up to date. In your Copilot session run '/skills reload' (or relaunch) to apply."
}

cmd_install() {
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude install -> %s ==\n' "$project"

  # 1. Skills: symlink each skill dir into <project>/.claude/skills so Copilot
  #    (and Claude) read them live; a git pull of the marketplace updates them
  #    with zero re-copy. Fall back to a copy if symlinks aren't supported.
  mkdir -p "$project/.claude/skills"
  local n=0
  if [ -d "$SKILLS_SRC" ]; then
    for d in "$SKILLS_SRC"/*/; do
      [ -d "$d" ] || continue
      local name; name="$(basename "$d")"
      local dest="$project/.claude/skills/$name"
      rm -rf "$dest"
      ln -s "$d" "$dest" 2>/dev/null || cp -r "$d" "$dest"
      n=$((n + 1))
    done
  fi
  ok "wired $n skills into .claude/skills (read live by Copilot + Claude)"

  # 2. Hooks: write a Copilot-schema hooks file into <project>/.github/hooks that
  #    routes each enforcement hook through the adapter (absolute paths into the
  #    marketplace checkout, so a git pull updates the behavior live).
  mkdir -p "$project/.github/hooks"
  local adapter="$CORE/hooks/copilot-hook-adapter.sh"
  python3 - "$project/.github/hooks/ravenclaude.json" "$adapter" "$CORE" <<'PY'
import json, sys
out, adapter, core = sys.argv[1], sys.argv[2], sys.argv[3]
h = core + "/hooks"
def bash(mode, script, *extra):
    return {"type": "command", "bash": f'"{adapter}" {mode} "{h}/{script}" ' + " ".join(extra),
            "timeoutSec": 90}
cfg = {
    "version": 1,
    "hooks": {
        "SessionStart": [bash("sessionstart", "capability-orientation.sh")],
        "PreToolUse": [
            bash("bash-pretool", "guard-destructive.sh"),
            bash("bash-pretool", "thing-orchestrator.sh"),
            bash("bash-pretool", "runaway-brake.sh"),
            bash("file-pretool", "enforce-layout.sh"),
        ],
        "PostToolUse": [
            bash("posttool", "format-on-write.sh"),
            bash("posttool", "claim-grounding-lint.sh"),
        ],
        "Stop": [
            bash("stop", "dod-gate.sh"),
            bash("stop", "remind-tests.sh"),
        ],
    },
}
open(out, "w").write(json.dumps(cfg, indent=2) + "\n")
PY
  ok "wired hooks into .github/hooks/ravenclaude.json (via the Copilot adapter)"

  # 3. MCP: merge the package's bundled servers into ~/.copilot/mcp-config.json.
  local mcp_src="$COPILOT_PKG/.mcp.json"
  local mcp_dest="${COPILOT_HOME:-$HOME/.copilot}/mcp-config.json"
  if [ -f "$mcp_src" ]; then
    mkdir -p "$(dirname "$mcp_dest")"
    python3 - "$mcp_src" "$mcp_dest" <<'PY'
import json, sys
src, dest = sys.argv[1], sys.argv[2]
try:
    add = json.load(open(src)).get("mcpServers", {})
except Exception:
    add = {}
try:
    cur = json.load(open(dest))
except Exception:
    cur = {}
cur.setdefault("mcpServers", {}).update(add)
open(dest, "w").write(json.dumps(cur, indent=2) + "\n")
print(f"  merged {len(add)} MCP server(s) into {dest}")
PY
    ok "merged bundled MCP servers into $mcp_dest"
  fi

  # 4. The launch alias — one command that updates then launches Copilot live.
  #    Suppressed when invoked by `setup`, which writes the alias to ~/.bashrc itself.
  if [ -z "${RC_FROM_SETUP:-}" ]; then
    printf '\nAdd this to your shell rc (~/.bashrc / ~/.zshrc) for one-command use:\n\n'
    printf "  alias rc='%s/scripts/ravenclaude update && copilot --plugin-dir %s'\n\n" "$MARKET" "$COPILOT_PKG"
    ok "install complete. Launch with:  copilot --plugin-dir $COPILOT_PKG"
    note "Updates from now on: just run 'ravenclaude update' (or 'rc'). No re-install, ever."
  fi
}

cmd_status() {
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude status -> %s ==\n' "$project"
  [ -d "$project/.claude/skills" ] && note "skills:  $(find "$project/.claude/skills" -maxdepth 1 -mindepth 1 -type l -o -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ') in .claude/skills" || note "skills:  not wired"
  [ -f "$project/.github/hooks/ravenclaude.json" ] && note "hooks:   .github/hooks/ravenclaude.json present" || note "hooks:   not wired"
  [ -f "${COPILOT_HOME:-$HOME/.copilot}/mcp-config.json" ] && note "mcp:     ~/.copilot/mcp-config.json present" || note "mcp:     not configured"
  [ -d "$COPILOT_PKG" ] && note "package: $COPILOT_PKG" || note "package: MISSING — run 'ravenclaude update' to generate it"
}

cmd_setup() {
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude setup -> %s ==\n' "$project"

  # 1. Wire skills + hooks + MCP (RC_FROM_SETUP suppresses install's alias hint).
  export RC_FROM_SETUP=1
  cmd_install --project "$project"
  unset RC_FROM_SETUP

  # 2. Seed a balanced comfort-posture if the repo doesn't already have one.
  local posture="$project/.ravenclaude/comfort-posture.yaml"
  local seed="$CORE/templates/comfort-posture-balanced.yaml"
  if [ -f "$posture" ]; then
    note "comfort-posture.yaml already present — left as-is"
  elif [ -f "$seed" ]; then
    mkdir -p "$project/.ravenclaude"
    cp "$seed" "$posture"
    ok "seeded .ravenclaude/comfort-posture.yaml (balanced default)"
  else
    warn "balanced posture template missing ($seed) — skipped posture seed"
  fi

  # 3. Apply the posture to .claude/settings.json (best-effort).
  local apply="$CORE/scripts/apply-comfort-posture.py"
  if [ -f "$posture" ] && [ -f "$apply" ] && command -v python3 >/dev/null 2>&1; then
    python3 "$apply" --project-root "$project" >/dev/null 2>&1 \
      && ok "applied comfort-posture -> .claude/settings.json" \
      || warn "could not apply comfort-posture (open the dashboard or run /set-posture later)"
  fi

  # 4. The one-word launch alias.
  add_rc_alias

  # 5. Repo-local comfort-posture dashboard launchers (scoped to this repo).
  wire_dashboard_launchers "$project"

  ok "setup complete. Launch with:  rc    (or: copilot --plugin-dir $COPILOT_PKG)"
  note "Edit this repo's posture anytime: bash .ravenclaude/dashboard.sh  (or the VS Code task 'RavenClaude: Comfort-posture dashboard')"
}

cmd_init_codespace() {
  local project="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  printf '== ravenclaude init-codespace -> %s ==\n' "$project"
  local tpl="$CORE/templates/codespace-copilot"
  [ -d "$tpl" ] || { warn "template missing: $tpl"; return 1; }
  mkdir -p "$project/.devcontainer"
  if [ -f "$project/.devcontainer/devcontainer.json" ]; then
    warn ".devcontainer/devcontainer.json exists — NOT overwritten. Merge the postCreateCommand from $tpl/devcontainer.json by hand."
  else
    cp "$tpl/devcontainer.json" "$project/.devcontainer/devcontainer.json"
    ok "wrote .devcontainer/devcontainer.json"
  fi
  cp "$tpl/ravenclaude-post-create.sh" "$project/.devcontainer/ravenclaude-post-create.sh"
  chmod +x "$project/.devcontainer/ravenclaude-post-create.sh"
  ok "wrote .devcontainer/ravenclaude-post-create.sh"
  note "Commit .devcontainer/ and (re)build the Codespace — setup then runs automatically."
}

cmd_dashboard() {
  local project="$PWD" port="8000"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      *) project="$1"; shift ;;
    esac
  done
  project="$(cd "$project" && pwd)"
  local server="$CORE/scripts/serve-dashboards.py"
  [ -f "$server" ] || { warn "dashboard server missing: $server"; return 1; }
  printf '== ravenclaude dashboard -> %s ==\n' "$project"
  note "Open the URL it prints (Codespace: Ports panel -> Open in Browser). Ctrl+C to stop."
  # --project-root pins the repo; the server hard-refuses if it ever resolves to the marketplace.
  exec python3 "$server" --project-root "$project" --port "$port"
}

case "${1:-}" in
  setup)          shift; cmd_setup "$@" ;;
  install)        shift; cmd_install "$@" ;;
  update)         cmd_update ;;
  status)         shift; cmd_status "$@" ;;
  dashboard)      shift; cmd_dashboard "$@" ;;
  init-codespace) shift; cmd_init_codespace "$@" ;;
  *) printf 'usage: ravenclaude {setup|install|update|status|dashboard|init-codespace} [--project DIR]\n'; exit 2 ;;
esac
